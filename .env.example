# Copy to .env and adjust as needed. Docker Compose sets these for containers;
# this file is for running the backend natively.

DATABASE_URL=postgresql://postgres:postgres@localhost:55432/packetiq

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=180
OLLAMA_NUM_CTX=8192

# Directories (default to <repo>/pcaps, <repo>/logs, <repo>/output)
#PCAP_DIR=
#LOG_DIR=
#OUTPUT_DIR=

# Detection thresholds (defaults shown)
#DETECT_PORT_SCAN_UNIQUE_PORTS=15
#DETECT_PORT_SCAN_UNIQUE_HOSTS=10
#DETECT_PORT_SCAN_WINDOW_SECS=60
#DETECT_DDOS_MIN_SRC_IPS=50
#DETECT_DDOS_MIN_CONNECTIONS=200
#DETECT_DDOS_WINDOW_SECS=60
#DETECT_BRUTE_FORCE_MIN_FAILED=5
#DETECT_BRUTE_FORCE_HIGH_RATIO=0.7
#DETECT_BRUTE_FORCE_WINDOW_SECS=120
#DETECT_BRUTE_FORCE_SMALL_BYTES=400
#DETECT_BRUTE_FORCE_MIN_SMALL=20
#DETECT_BRUTE_FORCE_SMALL_HIGH=100
#DETECT_HTTP_BRUTE_FORCE_MIN_FAILED=10

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
